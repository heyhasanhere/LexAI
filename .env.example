# Generated by install.sh — copy to .env and fill in values,
# or just run install.sh which writes this for you.

# ── Profile ───────────────────────────────────────────────────────────────
# lite  = use OpenAI API or a remote LLM endpoint (no GPU required)
# full  = use local Qwen3-14B on NVIDIA GPUs
COMPOSE_PROFILES=lite

# ── LLM backend ───────────────────────────────────────────────────────────
# OpenAI:
#   LD_LLM__BASE_URL=https://api.openai.com/v1
#   LD_LLM__MODEL=gpt-4o-mini
#   LD_LLM__API_KEY=sk-...
#
# LexAI remote GPU (ask the operator for the URL and key):
#   LD_LLM__BASE_URL=https://ai.lexai.app/v1
#   LD_LLM__MODEL=Qwen/Qwen3-14B-AWQ
#   LD_LLM__API_KEY=<your-lexai-key>
#
# Local vLLM (full profile only — set automatically by install.sh):
#   LD_LLM__BASE_URL=http://vllm:8000/v1
#   LD_LLM__MODEL=Qwen/Qwen3-14B-AWQ
#   LD_LLM__API_KEY=local

LD_LLM__BASE_URL=https://api.openai.com/v1
LD_LLM__MODEL=gpt-4o-mini
LD_LLM__API_KEY=sk-YOUR_KEY_HERE

# ── Optional: HuggingFace token (speeds up model downloads) ───────────────
HF_TOKEN=
